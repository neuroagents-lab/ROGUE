            data = part_data(part)
            base_name = clean_name(name, idx, part.get_content_type())
            stem = pathlib.Path(base_name).stem or "attachment"
            suffix = pathlib.Path(base_name).suffix
            cand = base_name
            n = 2
            while cand.lower() in used:
                cand = "%s_%d%s" % (stem, n, suffix); n += 1
            dest = folder / cand
            while dest.exists():
                try:
                    if dest.read_bytes() == data:
                        break
                except Exception:
                    pass
                cand = "%s_%d%s" % (stem, n, suffix); n += 1
                dest = folder / cand
            dest.write_bytes(data)
            used.add(cand.lower())
            idx += 1

