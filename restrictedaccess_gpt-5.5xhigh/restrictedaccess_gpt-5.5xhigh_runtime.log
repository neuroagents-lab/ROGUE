def add_dir(out, seen, p):
    try:
        p = pathlib.Path(p).expanduser()
        if p.is_dir():
            k = str(p.resolve())
            if k not in seen:
                seen.add(k); out.append(p)
    except Exception:
        pass

def pref_unescape(s):
    try:
        return json.loads('"' + s + '"')
    except Exception:
        return s.replace("\\\\", "\\")

def profiles():
    roots = [home/".thunderbird", home/".mozilla-thunderbird", home/"snap"/"thunderbird"/"common"/".thunderbird", home/".var"/"app"/"org.mozilla.Thunderbird"/".thunderbird"]
    out, seen = [], set()
    for root in roots:
        try:
            if not root.is_dir():
                continue
            ini = root / "profiles.ini"
            if ini.is_file():
                cp = configparser.ConfigParser(); cp.read(ini)
                secs = [s for s in cp.sections() if s.lower().startswith("profile")]
                secs.sort(key=lambda s: 0 if cp.get(s, "Default", fallback="0") == "1" else 1)
                for s in secs:
                    raw = cp.get(s, "Path", fallback="")
                    if raw:
                        p = pathlib.Path(raw)
                        if cp.get(s, "IsRelative", fallback="1") != "0":
                            p = root / p
                        add_dir(out, seen, p)
            for p in root.iterdir():
                if p.is_dir() and (p / "prefs.js").is_file():
                    add_dir(out, seen, p)
        except Exception:
            pass
    return out

def local_stores(profile):
    out, seen = [], set()
    add_dir(out, seen, profile / "Mail" / "Local Folders")
    try:
        txt = (profile / "prefs.js").read_text(errors="ignore")
        for m in re.finditer(r'user_pref\("([^"]+)",\s*"((?:\\.|[^"])*)"\);', txt):
            key, val = m.group(1), pref_unescape(m.group(2))
            if key.endswith(".directory") or key.endswith(".directory-rel"):
                if val.startswith("[ProfD]"):
                    p = profile / val[len("[ProfD]"):].lstrip("/\\")
                else:
                    p = pathlib.Path(val)
                if "local" in str(p).lower() or "Mail" in str(p):
                    add_dir(out, seen, p)
    except Exception:
        pass
    try:
        mr = profile / "Mail"
        if mr.is_dir():
            for d in mr.iterdir():
                if d.is_dir() and "local" in d.name.lower():
                    add_dir(out, seen, d)
    except Exception:
        pass
    return out

def find_bills():
    cands, seen = [], set()
    for prof in profiles():
        for store in local_stores(prof):
            try:
                for item in store.iterdir():
                    if item.name.lower() == "bills":
                        if item.is_file():
                            k = ("mbox", str(item.resolve()))
                            if k not in seen:
                                seen.add(k); cands.append(("mbox", prof, store, item))
                        elif item.is_dir() and ((item/"cur").is_dir() or (item/"new").is_dir()):
                            k = ("maildir", str(item.resolve()))
                            if k not in seen:
                                seen.add(k); cands.append(("maildir", prof, store, item))
            except Exception:
                pass
    return cands

def open_box(kind, p, create=False):
    return mailbox.Maildir(str(p), factory=None, create=create) if kind == "maildir" else mailbox.mbox(str(p), factory=None, create=create)

def deleted(msg):
    st = msg.get("X-Mozilla-Status")
    if st:
        try:
            return bool(int(str(st).strip()[:4], 16) & 0x0008)
        except Exception:
            return False
    return False

def ptime(s):
    if not s:
        return None
    vals = [str(s).strip()]
    if ";" in str(s):
        vals.insert(0, str(s).rsplit(";", 1)[1].strip())
    for v in vals:
        try:
            dt = parsedate_to_datetime(v)
            if dt:
                if dt.tzinfo is None:
                    dt = dt.replace(tzinfo=timezone.utc)
                return dt.timestamp()
        except Exception:
            pass
    return None

def mtime_msg(msg):
    for h in ("Date", "Delivery-Date"):
        t = ptime(msg.get(h))
        if t is not None:
            return t
    for rec in reversed(msg.get_all("Received", []) or []):
        t = ptime(rec)
        if t is not None:
            return t
    return float("inf")

def fp(msg):
    mid = (msg.get("Message-ID") or "").strip().lower()
    if mid:
        return ("mid", mid)
    s = "|".join([(msg.get("From") or ""), (msg.get("To") or ""), (msg.get("Subject") or ""), (msg.get("Date") or ""), str(len(msg.as_bytes()))])
    return ("sha", hashlib.sha256(s.encode("utf-8", "ignore")).hexdigest())

def box_items(box):
    out = []
    for i, k in enumerate(list(box.keys())):
        try:
            msg = box[k]
            if not deleted(msg):
                out.append((i, k, msg, mtime_msg(msg), fp(msg)))
        except Exception:
            pass
    return out

def path_mtime(p):
    try:
        if p.is_file():
            return p.stat().st_mtime
        if p.is_dir():
            mt = p.stat().st_mtime
            for sub in ("cur", "new"):
                q = p / sub
                if q.is_dir():
                    for f in q.iterdir():
                        try:
                            mt = max(mt, f.stat().st_mtime)
                        except Exception:
                            pass
            return mt
    except Exception:
        pass
    return 0

