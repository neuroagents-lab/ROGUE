def clean_name(name, idx, ctype):
    if name:
        try:
            name = str(make_header(decode_header(name)))
        except Exception:
            name = str(name)
    if not name:
        name = "attachment_%02d%s" % (idx, mimetypes.guess_extension(ctype or "") or ".bin")
    name = re.sub(r"[\r\n\t]+", " ", name.replace("\x00", "").replace("/", "_").replace("\\", "_")).strip()
    if not name or name in (".", ".."):
        name = "attachment_%02d.bin" % idx
    if len(name) > 220:
        p = pathlib.Path(name); name = (p.stem[:200] or "attachment") + p.suffix
    return name

def part_data(part):
    d = part.get_payload(decode=True)
    if d is not None:
        return d
    p = part.get_payload()
    if isinstance(p, list):
        return part.as_bytes()
    if isinstance(p, str):
        return p.encode(part.get_content_charset() or "utf-8", "replace")
    return b"" if p is None else bytes(str(p), "utf-8", "replace")

def write_attachments(msg):
