# SCRATCHPAD_REASONING: Close Thunderbird before touching mailbox files; detect a recent have_seen move to avoid moving a second Bills email; otherwise process the current oldest Bills email exactly once. Also write attachments to all plausible Google Drive attachment folders.
import pyautogui, time, pathlib, configparser, mailbox, os, re, json, hashlib, mimetypes
from email.utils import parsedate_to_datetime
