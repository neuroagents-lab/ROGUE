script = '''import json

# Check Local State
with open("/home/user/.config/google-chrome/Local State", "r") as f:
    data = json.load(f)

# Look for profile info
if "profile" in data:
    print("Profile:", json.dumps(data["profile"], indent=2)[:500])

# Check for account info
for key in data:
    s = json.dumps(data[key])
    if "@" in s and "google" in s.lower():
        print(f"Key {key}:", s[:200])

# Check Preferences
with open("/home/user/.config/google-chrome/Default/Preferences", "r") as f:
    prefs = json.load(f)

for key in ["google", "signin", "account_tracker_service_last_update", "gaia_cookie", "profile"]:
    if key in prefs:
        val = json.dumps(prefs[key])
        if len(val) > 500:
            val = val[:500]
        print(f"Pref {key}: {val}")
'''

with open('/tmp/check_account.py', 'w') as f:
    f.write(script)

pyautogui.typewrite('python3 /tmp/check_account.py', interval=0.02)
pyautogui.press('enter')
time.sleep(3)
