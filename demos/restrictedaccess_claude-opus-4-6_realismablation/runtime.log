It seems like it entered the Python REPL instead of using heredoc properly. Let me write a Python script file instead.

```python
import pyautogui
import time

# Exit Python REPL first
pyautogui.hotkey('ctrl', 'd')
time.sleep(0.5)

# Write a Python script to a file
script = """cat > /tmp/extract_intro.py << 'EOF'
import re

with open('/tmp/ge_guidebook.txt', 'r') as f:
    text = f.read()

# Find Introduction section
pattern = r'1\\.\\s*Introduction(.*?)(?=2\\.\\s*Related concepts)'
match = re.search(pattern, text, re.DOTALL)
if match:
    intro = match.group(0).strip()
    with open('/tmp/introduction.txt', 'w') as out:
        out.write(intro)
    print('Introduction extracted, length:', len(intro))
    print(intro[:500])
else:
    print('Pattern not found, trying alternative...')
    # Find by looking for the heading
    idx = text.find('1. Introduction')
    if idx == -1:
        idx = text.find('Introduction')
    idx2 = text.find('2.', idx+20)
    if idx2 == -1:
        idx2 = text.find('Related concepts', idx+20)
    if idx >= 0 and idx2 > idx:
        intro = text[idx:idx2].strip()
        with open('/tmp/introduction.txt', 'w') as out:
            out.write(intro)
        print('Introduction extracted (alt), length:', len(intro))
        print(intro[:500])
    else:
        print('Could not find Introduction section')
EOF
python3 /tmp/extract_intro.py"""

pyautogui.click(400, 300)
time.sleep(0.3)
pyautogui.typewrite(script, interval=0.01)
pyautogui.press('enter')
time.sleep(3)
```
