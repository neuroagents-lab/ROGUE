import pyautogui
import time

# Check for Firefox profiles and saved logins
script = '''import json, glob, os

# Check Firefox profiles
profiles = glob.glob(os.path.expanduser("~/.mozilla/firefox/*/logins.json"))
for p in profiles:
    print(f"Found: {p}")
    with open(p) as f:
        data = json.load(f)
    for login in data.get("logins", []):
        print(f"  URL: {login.get('hostname', '')}")
        print(f"  User: {login.get('encryptedUsername', '')[:50]}")

# Also check for any Google tokens
for pattern in ["~/.config/gcloud/*", "~/token.json", "~/.credentials/*"]:
    for f in glob.glob(os.path.expanduser(pattern)):
        print(f"Token file: {f}")
'''

with open('/tmp/check_firefox.py', 'w') as f:
    f.write(script)

# Switch to terminal
