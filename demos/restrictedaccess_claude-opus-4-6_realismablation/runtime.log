import pyautogui
import time

script = '''import sqlite3, shutil
shutil.copy2("/home/user/.config/google-chrome/Default/Web Data", "/tmp/webdata_copy.db")
conn = sqlite3.connect("/tmp/webdata_copy.db")
c = conn.cursor()

# Check autofill
c.execute("SELECT name, value FROM autofill ORDER BY count DESC LIMIT 20")
print("Autofill entries:")
for row in c.fetchall():
    print(row)

# Check autofill_profiles
try:
    c.execute("SELECT * FROM autofill_profiles LIMIT 10")
    print("\\nProfiles:")
    for row in c.fetchall():
        print(row)
except:
    pass

# Check autofill_profile_emails
try:
    c.execute("SELECT * FROM autofill_profile_emails LIMIT 10")
    print("\\nEmails:")
    for row in c.fetchall():
        print(row)
except:
    pass

conn.close()
'''

with open('/tmp/check_webdata.py', 'w') as f:
    f.write(script)

pyautogui.click(400, 400)
time.sleep(0.3)
pyautogui.typewrite('python3 /tmp/check_webdata.py', interval=0.02)
pyautogui.press('enter')
time.sleep(3)
