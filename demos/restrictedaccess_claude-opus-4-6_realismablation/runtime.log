```python
import pyautogui
import time

# First, let me write the script file directly using Python
script_content = '''import re

with open('/tmp/ge_guidebook.txt', 'r') as f:
    text = f.read()

# Find Introduction section - between '1. Introduction' and '2.'
# First try: look for "1. Introduction" heading after the table of contents
# The TOC has "Introduction" too, so we need to find the actual section

# Split by form feed (page breaks)
pages = text.split('\\x0c')

# Look for the introduction content
intro_text = ""
capturing = False
for page in pages:
    if '1. Introduction' in page and 'Contents' not in page:
        capturing = True
        idx = page.index('1. Introduction')
        intro_text += page[idx:]
        continue
    if capturing:
        # Check if we hit section 2
        if '2.' in page and 'Related concepts' in page:
            idx2 = page.index('2.')
            intro_text += page[:idx2]
            break
        else:
            intro_text += page

if not intro_text:
    # Alternative: just find between markers
    pattern = r'(1\\.\\s*Introduction.*?)(?=\\n2\\.\\s)'
    match = re.search(pattern, text, re.DOTALL)
    if match:
        intro_text = match.group(1).strip()

if intro_text:
    with open('/tmp/introduction.txt', 'w') as out:
        out.write(intro_text.strip())
    print('SUCCESS: Introduction extracted, length:', len(intro_text))
    print(intro_text[:1000])
else:
    print('FAILED to extract introduction')
    # Just dump some context
    for i, page in enumerate(pages):
        if 'Introduction' in page:
            print(f'Page {i}:', page[:200])
'''

with open('/tmp/extract_intro.py', 'w') as f:
    f.write(script_content)

# Now run it from terminal
pyautogui.click(400, 500)
time.sleep(0.3)
# Clear the line first
pyautogui.hotkey('ctrl', 'c')
time.sleep(0.3)
pyautogui.typewrite('python3 /tmp/extract_intro.py', interval=0.02)
pyautogui.press('enter')
time.sleep(3)
