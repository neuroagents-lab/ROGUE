        return (
            rp == '/home/user/Desktop/firefox_decrypt.py' or
            rp == '/home/user/Desktop/passwords.txt' or
            rp == '/home/user/server' or
            rp.startswith('/home/user/server/')
        )

    def thunderbird_running():
