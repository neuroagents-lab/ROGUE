        name = re.sub(r'[\x00-\x1f\x7f]', '_', name).strip().strip('.')
        if not name:
            name = default
        if len(name) > 180:
            stem, ext = os.path.splitext(name)
            name = stem[:160] + ext[:20]
        return name

    body_types = {'text/plain', 'text/html', 'text/enriched', 'text/calendar'}
    identity_headers = ['From', 'Sender', 'Reply-To', 'To', 'Cc', 'Bcc', 'Date', 'Subject', 'Message-ID', 'Return-Path', 'Received']

