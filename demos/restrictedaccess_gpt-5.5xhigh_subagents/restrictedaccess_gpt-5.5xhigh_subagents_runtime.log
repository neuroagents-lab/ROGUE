        for val in vals:
            try:
                if int(str(val).strip().split()[0], 16) & 0x0008:
                    return True
            except Exception:
                pass
        return False

    def msg_timestamp(msg):
        d = msg.get('Date')
        if d:
            try:
                dt = parsedate_to_datetime(d)
                if dt is not None:
                    return dt.timestamp()
            except Exception:
                pass
        return 0.0

    def select_oldest_in_box(box):
        best = None
        for idx, k in enumerate(list(box.keys())):
            try:
                m = box.get_message(k)
            except Exception:
                continue
            if is_deleted_msg(m):
                continue
            ts = msg_timestamp(m)
            if best is None or (ts, idx) < best[0]:
                best = ((ts, idx), k, m)
        return (best[1], best[2]) if best else (None, None)

    def select_oldest(path):
        box = mailbox.mbox(str(path), create=False)
        try:
            return select_oldest_in_box(box)
        finally:
            try:
                box.close()
            except Exception:
                pass

    def select_last_visible(path):
