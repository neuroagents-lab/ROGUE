                        except Exception:
                            pass
        if not cands:
            raise RuntimeError("Could not find Thunderbird Local Folders/Bills mbox file.")
        def score(p):
            parts = [x.lower() for x in p.parts]
            sc = 0
            if 'mail' in parts:
                sc += 20
            if any(x == 'local folders' for x in parts):
                sc += 100
            try:
                sc += min(50, int(p.stat().st_size / 1024))
            except Exception:
