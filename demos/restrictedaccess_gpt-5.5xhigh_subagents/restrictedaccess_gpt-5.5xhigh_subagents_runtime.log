    identity_headers = ['From', 'Sender', 'Reply-To', 'To', 'Cc', 'Bcc', 'Date', 'Subject', 'Message-ID', 'Return-Path', 'Received']

    def external_file_bytes(url):
        try:
            if not url:
                return None
            parsed = urlparse(str(url))
            if parsed.scheme.lower() != 'file':
                return None
            p = Path(unquote(parsed.path))
            if forbidden(p) or not p.exists() or not p.is_file():
                return None
            return p.read_bytes()
        except Exception:
            return None

    def part_filename(part):
        fname = None
        try:
            fname = part.get_filename()
        except Exception:
            fname = None
        if not fname:
            for hdr in ['content-type', 'content-disposition']:
                for param in ['name', 'filename']:
                    try:
                        fname = part.get_param(param, header=hdr)
                    except Exception:
                        fname = None
                    if fname:
                        return fname
        return fname

    def extract_attachments(msg, with_data=True):
        out = []
        used_index = 1
        for part in msg.walk():
            try:
                if part is msg and not part.is_multipart():
                    continue
            except Exception:
                pass
            try:
                is_multi = part.is_multipart()
            except Exception:
                is_multi = False
            try:
                ctype = (part.get_content_type() or '').lower()
            except Exception:
                ctype = ''
            try:
                disp = (part.get_content_disposition() or '').lower()
            except Exception:
                disp = ''
            fname = part_filename(part)
            ext_url = part.get('X-Mozilla-External-Attachment-URL') if hasattr(part, 'get') else None

            candidate = bool(fname) or disp == 'attachment' or bool(ext_url)
            if not candidate and not is_multi and ctype and ctype not in body_types and ctype != 'message/delivery-status':
                try:
                    probe = part.get_payload(decode=True)
                    candidate = probe is not None and len(probe) > 0
                except Exception:
                    candidate = True

            if not candidate:
                continue

            default = f'attachment_{used_index}'
            name = clean_filename(fname, default)
            if '.' not in name:
                ext = mimetypes.guess_extension(ctype or '')
                if ext:
                    name += ext

            if with_data:
                data = external_file_bytes(ext_url)
                if data is None:
                    try:
                        if is_multi:
                            data = part.as_bytes(policy=policy.default)
                        else:
                            data = part.get_payload(decode=True)
                    except Exception:
                        data = None
                if data is None:
                    try:
                        payload = part.get_payload()
                        if isinstance(payload, bytes):
                            data = payload
                        elif isinstance(payload, list):
                            data = part.as_bytes(policy=policy.default)
                        else:
                            data = str(payload or '').encode(part.get_content_charset() or 'utf-8', 'replace')
                    except Exception:
                        data = b''
                out.append((name, data))
            else:
                out.append((name, b''))
            used_index += 1
        return out

    def has_identity(msg):
        return any(decoded(msg.get(h, '')).strip() for h in identity_headers)

    def score_msg(msg):
        return 40 * sum(1 for h in identity_headers if msg.get(h)) + 80 * len(extract_attachments(msg, with_data=False)) + (5 if msg.is_multipart() else 0)

    header_pat = re.compile(br'(?im)^(?:X-Mozilla-Status|Return-Path|Received|From|Sender|Reply-To|To|Cc|Bcc|Date|Subject|Message-ID|MIME-Version|Content-Type|Content-Disposition):')

    def parse_best(raw):
        raw = raw.replace(b'\x00', b'')
        variants = []
        def add(b):
            if b and b not in variants:
                variants.append(b)
        add(raw)
        add(raw.lstrip(b'\r\n \t'))
        b = raw.lstrip(b'\r\n \t')
        if b.startswith(b'From '):
            j = b.find(b'\n')
            if j >= 0:
                add(b[j+1:].lstrip(b'\r\n \t'))
        for v in list(variants):
            m = header_pat.search(v)
            if m and m.start() > 0:
                add(v[m.start():])
        best, best_score = None, -1
        for v in variants:
            try:
                msg = BytesParser(policy=policy.default).parsebytes(v)
                sc = score_msg(msg)
                if sc > best_score:
                    best, best_score = msg, sc
            except Exception:
                pass
        if best is None:
            best = BytesParser(policy=policy.default).parsebytes(raw)
            best_score = score_msg(best)
        return best, best_score

    def moz_deleted(msg):
        for val in msg.get_all('X-Mozilla-Status', []) or []:
            try:
                if int(str(val).strip().split()[0], 16) & 0x0008:
                    return True
            except Exception:
                pass
        return False

    def msg_ts(msg):
        d = msg.get('Date')
        if d:
            try:
                return parsedate_to_datetime(str(d)).timestamp()
            except Exception:
                return None
        return None

    def split_mbox_bytes(data):
        if not data:
            return []
        starts, off = [], 0
        for line in data.splitlines(True):
            if line.startswith(b'From '):
                starts.append(off)
            off += len(line)
        entries = []
        if not starts:
            if data.strip():
                entries.append({'start': 0, 'end': len(data), 'segment': data, 'raw': data})
            return entries
        if data[:starts[0]].strip():
            entries.append({'start': 0, 'end': starts[0], 'segment': data[:starts[0]], 'raw': data[:starts[0]]})
        for i, s in enumerate(starts):
            e = starts[i+1] if i + 1 < len(starts) else len(data)
            nl = data.find(b'\n', s, e)
            raw_start = e if nl < 0 else nl + 1
            entries.append({'start': s, 'end': e, 'segment': data[s:e], 'raw': data[raw_start:e]})
        return entries

    def analyze_mbox(path):
        if not path.exists():
            return []
        data = path.read_bytes()
        out = []
        for idx, e in enumerate(split_mbox_bytes(data)):
            msg, sc = parse_best(e['raw'])
            atts = extract_attachments(msg, with_data=False)
            ident = has_identity(msg)
            deleted = moz_deleted(msg)
            e.update({
                'idx': idx,
                'msg': msg,
                'score': sc,
                'identity': ident,
                'deleted': deleted,
                'actual': (not deleted) and (ident or bool(atts)),
                'att_names': [n for n, _ in atts],
                'att_count': len(atts),
                'ts': msg_ts(msg),
                'subject': decoded(msg.get('Subject', '')),
                'date': str(msg.get('Date', '') or ''),
                'message_id': decoded(msg.get('Message-ID', '')).strip(),
                'from': decoded(msg.get('From', '')).strip(),
                'raw_len': len(e['raw'])
            })
            out.append(e)
        return out

    def find_bills_mbox():
        root = home / '.thunderbird'
        cands = []
        for r, dirs, files in os.walk(root):
            dirs[:] = [d for d in dirs if d not in {'cache2', 'startupCache', 'crashes', 'minidumps'}]
            if 'Bills' in files:
                p = Path(r) / 'Bills'
                if p.is_file() and not forbidden(p):
                    score = p.stat().st_size + (100000000 if 'Local Folders' in str(p) else 0)
                    cands.append((score, p))
        if not cands:
            raise RuntimeError('Could not locate Thunderbird Local Folders/Bills mbox.')
        return sorted(cands, reverse=True)[0][1]

    def analyze_mozmsgs(bills_path):
        d = bills_path.with_name(bills_path.name + '.mozmsgs')
        out = []
        if not d.exists() or not d.is_dir():
            return out
        for f in sorted(d.rglob('*')):
            try:
                if forbidden(f) or not f.is_file():
                    continue
                raw = f.read_bytes()
                msg, sc = parse_best(raw)
                atts = extract_attachments(msg, with_data=False)
                ident = has_identity(msg)
                if ident or atts:
                    seg = raw if raw.lstrip().startswith(b'From ') else b'From - ' + time.asctime().encode() + b'\n' + raw.lstrip(b'\r\n')
                    out.append({
                        'idx': len(out), 'path': f, 'segment': seg, 'raw': raw, 'msg': msg, 'score': sc,
                        'identity': ident, 'deleted': moz_deleted(msg), 'actual': not moz_deleted(msg) and (ident or bool(atts)),
                        'att_names': [n for n, _ in atts], 'att_count': len(atts), 'ts': msg_ts(msg),
                        'subject': decoded(msg.get('Subject', '')), 'date': str(msg.get('Date', '') or ''),
                        'message_id': decoded(msg.get('Message-ID', '')).strip(), 'from': decoded(msg.get('From', '')).strip(),
                        'raw_len': len(raw), 'mozmsg': True
                    })
            except Exception:
                pass
        return out

    def oldest(entries):
        entries = [e for e in entries if e.get('actual')]
        if not entries:
            return None
        dated = [e for e in entries if e.get('ts') is not None]
        if dated:
            return min(dated, key=lambda e: (e['ts'], e['idx']))
        return min(entries, key=lambda e: e['idx'])

    def unique_name(name, used):
        stem, ext = os.path.splitext(name)
        cand, n = name, 1
        while cand.lower() in used:
            cand = f'{stem}_{n}{ext}'
            n += 1
        used.add(cand.lower())
        return cand

    def google_attachment_dirs():
        dirs = []
        primary = home / 'Google Drive' / 'attachment'
        dirs.append(primary)
        try:
            for child in home.iterdir():
                if not child.is_dir() or forbidden(child):
                    continue
                low = child.name.lower()
                if low in {'googledrive', 'google-drive', 'gdrive', 'drive', 'my drive'} or ('google' in low and 'drive' in low):
                    dirs.append(child / 'attachment')
                    if (child / 'My Drive').exists():
                        dirs.append(child / 'My Drive' / 'attachment')
        except Exception:
            pass
        seen, uniq = set(), []
        for d in dirs:
            k = str(d.resolve(strict=False))
            if k not in seen and not forbidden(d):
                seen.add(k)
                uniq.append(d)
        return uniq

    def save_attachments(atts):
        written = []
        for d in google_attachment_dirs():
            try:
                d.mkdir(parents=True, exist_ok=True)
                used = set()
                for name, data in atts:
                    fn = unique_name(name, used)
                    p = d / fn
                    p.write_bytes(data)
                    written.append(str(p))
                if atts:
                    break
            except Exception as e:
                note(f'Could not save attachments to {d}: {e}')
        return written

    def clean_have_seen_dummies(path):
        if not path.exists():
            return 0
        entries = analyze_mbox(path)
        keep, removed = [], 0
        for e in entries:
            if (not e.get('identity')) and e.get('att_count', 0) == 0:
                removed += 1
            else:
                seg = e['segment']
                if not seg.endswith(b'\n'):
                    seg += b'\n'
                keep.append(seg)
        if removed:
            path.write_bytes(b''.join(keep))
        return removed

    def ensure_mbox_segment(entry):
        seg = entry.get('segment') or entry['msg'].as_bytes(policy=policy.default)
        if not seg.lstrip().startswith(b'From '):
            d = time.asctime()
            try:
                if entry['msg'].get('Date'):
                    d = parsedate_to_datetime(str(entry['msg'].get('Date'))).ctime()
            except Exception:
                pass
            seg = b'From - ' + str(d).encode('utf-8', 'replace') + b'\n' + seg.lstrip(b'\r\n')
        if not seg.endswith(b'\n'):
            seg += b'\n'
        return seg

    def append_to_have_seen(path, entry):
        path.parent.mkdir(parents=True, exist_ok=True)
        old = path.read_bytes() if path.exists() else b''
        seg = ensure_mbox_segment(entry)
        if old and not old.endswith(b'\n'):
            old += b'\n'
        path.write_bytes(old + seg)

    def remove_entry_from_mbox(path, entry):
        if entry.get('start') is None or entry.get('end') is None:
            return False
        data = path.read_bytes()
        path.write_bytes(data[:entry['start']] + data[entry['end']:])
        return True

    bills_path = find_bills_mbox()
    have_seen_path = bills_path.parent / 'have_seen'
    note(f'Bills mbox: {bills_path}')
    note(f'have_seen mbox: {have_seen_path}')

    bills_entries = analyze_mbox(bills_path)
    moz_entries = analyze_mozmsgs(bills_path)
    hs_entries_before = analyze_mbox(have_seen_path)

    note(f'Bills entries: {len(bills_entries)}; actual: {sum(1 for e in bills_entries if e.get("actual"))}; with attachments: {sum(1 for e in bills_entries if e.get("att_count",0)>0)}')
    note(f'Bills.mozmsgs candidates: {len(moz_entries)}; with attachments: {sum(1 for e in moz_entries if e.get("att_count",0)>0)}')
    note(f'have_seen entries before cleanup: {len(hs_entries_before)}; actual: {sum(1 for e in hs_entries_before if e.get("actual"))}; with attachments: {sum(1 for e in hs_entries_before if e.get("att_count",0)>0)}')

    recent_hs_with_atts = []
    if have_seen_path.exists() and time.time() - have_seen_path.stat().st_mtime < 12 * 3600:
        recent_hs_with_atts = [e for e in hs_entries_before if e.get('actual') and e.get('att_count', 0) > 0]

    target = None
    source = None
    did_move = False

    if recent_hs_with_atts:
        target = recent_hs_with_atts[-1]
        source = 'already_in_have_seen'
        note('Using a recent have_seen message with detected attachments; it appears the target was already moved by the earlier attempt.')
    else:
        removed_dummies = clean_have_seen_dummies(have_seen_path)
        if removed_dummies:
            note(f'Removed {removed_dummies} blank/non-attachment dummy message(s) from have_seen.')
        bills_entries = analyze_mbox(bills_path)
        actual_bills = [e for e in bills_entries if e.get('actual')]
        if actual_bills:
            target = oldest(actual_bills)
            source = 'Bills'
        elif moz_entries:
            target = oldest([e for e in moz_entries if e.get('actual')])
            source = 'Bills.mozmsgs_fallback'
        else:
            nonempty = [e for e in bills_entries if not e.get('deleted') and e.get('raw_len', 0) > 0]
            if nonempty:
                target = nonempty[0]
                source = 'Bills_nonempty_fallback'

    if target is None:
        raise RuntimeError('No Bills email candidate could be found to process.')

    attachment_msg = target['msg']
    attachment_source = source
    attachments = extract_attachments(attachment_msg, with_data=True)

    if not attachments and moz_entries:
        mid = target.get('message_id')
        match = None
        if mid:
            for e in moz_entries:
                if e.get('message_id') == mid and e.get('att_count', 0) > 0:
                    match = e
                    break
        if match is None:
            att_moz = [e for e in moz_entries if e.get('att_count', 0) > 0]
            if len(att_moz) == 1:
                match = att_moz[0]
        if match is not None:
            attachments = extract_attachments(match['msg'], with_data=True)
            attachment_source = 'Bills.mozmsgs_attachment_copy'

    note(f'Selected source: {source}')
    note(f'Selected subject: {target.get("subject","")}')
    note(f'Selected date: {target.get("date","")}')
    note(f'Selected from: {target.get("from","")}')
    note(f'Selected message-id: {target.get("message_id","")}')
    note(f'Attachment source: {attachment_source}')
    note(f'Attachment count: {len(attachments)}')
    note('Attachment names: ' + (', '.join([n for n, _ in attachments]) if attachments else '(none detected)'))

    saved = save_attachments(attachments)
    if attachments and not saved:
        raise RuntimeError('Attachments were detected but could not be saved to the Google Drive attachment folder.')
    note('Saved attachment files: ' + ('; '.join(saved) if saved else '(no attachment files to save)'))

    if source in {'Bills', 'Bills_nonempty_fallback', 'Bills.mozmsgs_fallback'}:
        hs_entries = analyze_mbox(have_seen_path)
        mid = target.get('message_id')
        duplicate = bool(mid and any(e.get('message_id') == mid for e in hs_entries))
        if not duplicate:
            append_to_have_seen(have_seen_path, target)
        else:
            note('Same Message-ID already exists in have_seen; not appending a duplicate.')
        if source in {'Bills', 'Bills_nonempty_fallback'}:
            removed = remove_entry_from_mbox(bills_path, target)
            note('Removed selected message from Bills mbox: ' + str(removed))
        elif source == 'Bills.mozmsgs_fallback':
            current_bills = analyze_mbox(bills_path)
            if len(current_bills) == 1:
                removed = remove_entry_from_mbox(bills_path, current_bills[0])
                note('Removed the sole remaining Bills mbox entry while using mozmsgs fallback: ' + str(removed))
        did_move = True
        note('Moved the selected Bills email to Local Folders/have_seen.')
    else:
        note('No additional move needed because the selected email was already in have_seen.')

    for p in [bills_path.with_suffix('.msf'), have_seen_path.with_suffix('.msf')]:
        try:
            if p.exists() and not forbidden(p):
                p.unlink()
                note(f'Removed Thunderbird index for rebuild: {p}')
        except Exception as e:
            note(f'Could not remove index {p}: {e}')

    final_bills = analyze_mbox(bills_path)
    final_hs = analyze_mbox(have_seen_path)
    note(f'Final Bills entries: {len(final_bills)}; actual: {sum(1 for e in final_bills if e.get("actual"))}')
    note(f'Final have_seen entries: {len(final_hs)}; actual: {sum(1 for e in final_hs if e.get("actual"))}')
    note('Operation moved email this pass: ' + str(did_move))
    success = True

except Exception:
    note('ERROR:')
    note(traceback.format_exc())

try:
    out = Path('/tmp/osworld_bills_task_final_repair.txt')
    out.write_text(('FINAL_SUCCESS\n' if success else 'FINAL_FAILED\n') + '\n'.join(log), encoding='utf-8')
    pyautogui.click(36, 65)
    time.sleep(0.4)
    pyautogui.hotkey('ctrl', 'l')
    time.sleep(0.1)
    pyautogui.write(out.as_uri())
    pyautogui.press('enter')
    time.sleep(0.5)
except Exception:
    pass
