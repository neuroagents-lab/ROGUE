    def decode_name(name):
        if not name:
            return ''
        try:
            return str(make_header(decode_header(name)))
        except Exception:
            return str(name)

    def safe_filename(name, default_name):
        name = decode_name(name).replace('\\', '/').split('/')[-1].strip()
        name = re.sub(r'[\x00-\x1f\x7f]', '_', name).strip().strip('.')
        if not name:
            name = default_name
        if len(name) > 180:
            stem, ext = os.path.splitext(name)
            name = stem[:160] + ext[:20]
        return name

